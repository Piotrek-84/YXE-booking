generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum BookingStatus {
  REQUESTED
  CONFIRMED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELED
  NO_SHOW
}

enum DiscountType {
  PERCENTAGE
  FIXED_CENTS
}

model Location {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services  Service[]
  addOns    AddOn[]
  bookings  Booking[]
  hours     LocationHours[]
  overrides AvailabilityOverride[]
  blackouts BlackoutDate[]
  capacityRule CapacityRule?
  slotBlocks SlotBlock[]
}

model Service {
  id              String   @id @default(cuid())
  locationId      String
  name            String
  description     String
  basePriceCents  Int
  durationMinutes Int
  bufferMinutes   Int      @default(0)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  location Location @relation(fields: [locationId], references: [id])
  bookings Booking[]
  intakeFields ServiceIntakeField[]
}

model AddOn {
  id              String   @id @default(cuid())
  locationId      String
  name            String
  description     String
  priceCents      Int
  durationMinutes Int
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  location    Location      @relation(fields: [locationId], references: [id])
  bookingLinks BookingAddOn[]
}

model Customer {
  id        String   @id @default(cuid())
  fullName  String
  phone     String
  email     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicles  Vehicle[]
  bookings  Booking[]
}

model Vehicle {
  id         String   @id @default(cuid())
  customerId String
  size       String?
  year       Int?
  make       String
  model      String
  trim       String?
  color      String?
  plate      String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])
  bookings Booking[]
}

model Booking {
  id              String        @id @default(cuid())
  locationId      String
  customerId      String
  vehicleId       String
  serviceId       String
  customerName    String?
  customerEmail   String?
  customerPhone   String?
  serviceName     String?
  durationMinutes Int?
  bufferMinutes   Int           @default(0)
  intakeAnswers   Json?
  clientManageToken String?     @unique
  tokenExpiresAt  DateTime?
  updatedBy       String?
  bookingStartDateTime DateTime?
  startAt          DateTime?
  endAt            DateTime?
  slotKey         String?
  slotSequence    Int?
  googleEventId   String?
  squareCustomerId String?
  companyCamProjectId String?
  clientDeviceHash String?
  requestedDate   DateTime
  requestedWindow String
  status          BookingStatus @default(REQUESTED)
  customerNotes   String?
  adminNotes      String?
  canceledAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  location Location @relation(fields: [locationId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  vehicle  Vehicle  @relation(fields: [vehicleId], references: [id])
  service  Service  @relation(fields: [serviceId], references: [id])
  addOns   BookingAddOn[]
  audits   BookingAudit[]
  reminders ReminderLog[]

  @@index([clientDeviceHash])
}

model BookingAddOn {
  bookingId String
  addOnId   String
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id])
  addOn   AddOn   @relation(fields: [addOnId], references: [id])

  @@id([bookingId, addOnId])
}

model LocationHours {
  id         String   @id @default(cuid())
  locationId String
  weekday    Int
  openTime   String
  closeTime  String
  isClosed   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  location Location @relation(fields: [locationId], references: [id])

  @@unique([locationId, weekday])
}

model AvailabilityOverride {
  id         String   @id @default(cuid())
  locationId String
  date       DateTime
  openTime   String?
  closeTime  String?
  isClosed   Boolean  @default(false)
  reason     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  location Location @relation(fields: [locationId], references: [id])

  @@unique([locationId, date])
}

model BlackoutDate {
  id         String   @id @default(cuid())
  locationId String
  startAt    DateTime
  endAt      DateTime
  reason     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  location Location @relation(fields: [locationId], references: [id])
}

model CapacityRule {
  id                 String   @id @default(cuid())
  locationId         String   @unique
  maxBookingsPerSlot Int      @default(4)
  slotIntervalMinutes Int     @default(30)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  location Location @relation(fields: [locationId], references: [id])
}

model ServiceIntakeField {
  id          String   @id @default(cuid())
  serviceId   String
  key         String
  label       String
  fieldType   String
  required    Boolean  @default(false)
  options     Json?
  sortOrder   Int      @default(0)
  placeholder String?
  helperText  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  service Service @relation(fields: [serviceId], references: [id])

  @@unique([serviceId, key])
}

model ReminderLog {
  id           String   @id @default(cuid())
  bookingId    String
  reminderType String
  sendAt       DateTime
  sentAt       DateTime?
  status       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([bookingId, reminderType, sendAt])
}

model BookingAudit {
  id        String   @id @default(cuid())
  bookingId String
  action    String
  actor     String?
  details   Json?
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model IntegrationLog {
  id              String   @id @default(cuid())
  provider        String
  eventType       String
  bookingId       String?
  direction       String   @default("OUTBOUND")
  status          String
  attempts        Int      @default(0)
  error           String?
  requestPayload  Json?
  responsePayload Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([provider, createdAt])
  @@index([bookingId, createdAt])
}

model NotificationLog {
  id              String   @id @default(cuid())
  bookingId       String?
  channel         String
  notificationType String
  dedupeKey       String   @unique
  status          String
  provider        String?
  toAddress       String?
  payload         Json?
  error           String?
  sendAt          DateTime?
  sentAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([bookingId, createdAt])
  @@index([notificationType, createdAt])
}

model BlockedCustomer {
  id        String   @id @default(cuid())
  fullName  String?
  phone     String
  email     String?
  clientFacingNote String?
  reason    String?
  blockedBy String?
  isActive  Boolean  @default(true)
  isPotentialMaintenance Boolean @default(false)
  maintenanceReason String?
  maintenanceMarkedAt DateTime?
  maintenanceMarkedBy String?
  unblockedAt DateTime?
  unblockedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([email])
  @@index([isActive])
  @@index([isPotentialMaintenance])
}

model BlockedDevice {
  id                      String   @id @default(cuid())
  deviceHash              String   @unique
  reason                  String?
  blockedBy               String?
  isActive                Boolean  @default(true)
  linkedBlockedCustomerId String?
  unblockedAt             DateTime?
  unblockedBy             String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([isActive])
  @@index([linkedBlockedCustomerId])
}

model SlotBlock {
  id          String   @id @default(cuid())
  locationId  String
  slotKey     String
  slotLine    Int
  reason      String?
  blockedBy   String?
  startAt     DateTime
  endAt       DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, slotKey, slotLine])
  @@index([locationId, startAt])
}

model DiscountCode {
  id               String       @id @default(cuid())
  code             String       @unique
  description      String?
  discountType     DiscountType
  percentOff       Int?
  fixedAmountCents Int?
  startsAt         DateTime?
  endsAt           DateTime?
  maxRedemptions   Int?
  redemptionCount  Int          @default(0)
  isActive         Boolean      @default(true)
  createdBy        String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([isActive, code])
  @@index([startsAt, endsAt])
}
